library(tidyverse)
library(arrow)
#get a connection to part of the data
PFW_all_1988_2000 <- open_dataset(
sources = "~/../shared/feederwatch/PFW_all_1988_1995_May2024_Public.csv",
format = "csv" )
PFW_all_1988_2000 |> glimpse()
#rare birds by month
PFW_all_1988_2000 |>
group_by(Year,Month,SPECIES_CODE) |>
summarise(birds = sum(HOW_MANY)) |>
filter(birds < 10) |>
collect()
view(PFW_all_1988_2000)
