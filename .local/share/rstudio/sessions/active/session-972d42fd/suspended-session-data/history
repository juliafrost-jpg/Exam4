library(tidyverse)
library(lubridate)
library(gsheet)
fishdata <- read_csv('https://tinyurl.com/fish439')
head(fishdata)
ggplot(data = fishdata, mapping = aes(x = Temperature_C, y = `Per capita N excretion rate`))+geom_point()
ggplot2::aes(x, y)
#Relationship between temp and nitrogen excretion
ggplot(data = fishdata, mapping = aes(x = Temperature_C, y = `Per capita N excretion rate`))+geom_point()+geom_smooth(method = "lm")
#Relationship between temp and nitrogen excretion
ggplot(data = fishdata, mapping = aes(x = Temperature_C, y = `Per capita N excretion rate`))+geom_point()+geom_smooth(method = "lm")
#Relationship between temp and nitrogen excretion
ggplot(data = fishdata, mapping = aes(x = Temperature_C, y = `Per capita N excretion rate`))+geom_point()+geom_smooth(method = "lm", se = FALSE)
#Weight and N excretion
ggplot(data = fishdata, mapping = aes(x = `Body mass_g`, `Per capita N excretion rate`))+geom_point()+geom_smooth(method = "lm", se = FALSE)
#frequncy of different sizes of fish
ggplot(fishdata, aes(`Body mass_g`))+geom_histogram()
