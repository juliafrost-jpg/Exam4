view(mtsthelens_data)
library(tidyverse)
library(ggplot2)
mtsthelens_data <- read_csv('https://tinyurl.com/mtsthelens222')
view(mtsthelens_data)
ggplot(data = mtsthelens_data, mapping = aes(x = year, y = `richness`))+geom_point()+geom_smooth(method = "lm", se = FALSE)
ggplot2::aes(x, y)
#Fit regression model model <- lm (response ~ explanatory 1 + explanatory 2, data = data)
model <- lm(richness ~ year + cover_percent, data = mtsthelens_data)
#Get regression table:
summary(model)
