sequence = 'ATGGATTTTAA'
substring_counts = {} #keep track of counts of substrings
size = 3

#go through substrings one at a time 
for i in range(len(sequence)-(size-1)): #go through bases one at a time
  substring = sequence[i:i+size] #get substring - base and additional bases based on size
  if substring in substring_counts:
    substring_counts[substring] += 1
  else:
    substring_counts[substring] = 1
print(substring_counts)
    

  
