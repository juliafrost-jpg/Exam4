srccontainersize 365984
srccontainerchecksum cce18b4529df7b39d72bf41a99a0dda9688933c4af1454d74f1165d5f69e8917da5de982d1a3ff3ca3577211083a870a3d2de0e8f41f2d2c8f9b3b3e36a9a10b
runfiles size=79
 texmf-dist/bibtex/bst/amscls/amsalpha.bst
 texmf-dist/bibtex/bst/amscls/amsplain.bst
 texmf-dist/tex/latex/amscls/amsart.cls
 texmf-dist/tex/latex/amscls/amsbook.cls
